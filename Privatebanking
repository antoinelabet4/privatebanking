                    {form.sciActionnaires.length > 1 && <button onClick={() => setF("sciActionnaires", form.sciActionnaires.filter((_,j) => j !== i))} style={{ background: "none", border: "none", color: "#555", cursor: "pointer", fontSize: 14 }}>✕</button>}
                  </div>
