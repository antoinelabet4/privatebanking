                        ...(b.usage === "locatif" ? [
                          { l: "LOYER HC/MOIS",    v: Math.round(getLoyer(b)) + " €", c: "#00E1DC" },
                          { l: "CASH-FLOW/MOIS",   v: (cf >= 0 ? "+" : "") + Math.round(cf) + " €", c: cf >= 0 ? "#4a9e6b" : "#e05555" },
